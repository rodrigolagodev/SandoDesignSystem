{
  "name": "@sando-ds/components",
  "version": "0.1.0",
  "description": "Web Components library for Sando Design System built with Lit",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./mixins": {
      "import": "./dist/mixins/index.js",
      "types": "./dist/mixins/index.d.ts"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    },
    "./styles/tokens": {
      "import": "./dist/styles/tokens.js",
      "types": "./dist/styles/tokens.d.ts"
    },
    "./styles/shared": {
      "import": "./dist/styles/shared/index.js",
      "types": "./dist/styles/shared/index.d.ts"
    },
    "./*": {
      "import": "./dist/components/*/sando-*.js",
      "types": "./dist/components/*/sando-*.d.ts"
    }
  },
  "files": ["dist", "custom-elements.json", "README.md", "LICENSE", "CHANGELOG.md"],
  "sideEffects": [
    "./dist/components/**/sando-*.js",
    "./dist/index.js",
    "**/*.css"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrigolagodev/SandoDesignSystem.git",
    "directory": "packages/components"
  },
  "homepage": "https://sando.rlago.com",
  "bugs": {
    "url": "https://github.com/rodrigolagodev/SandoDesignSystem/issues"
  },
  "customElements": "./custom-elements.json",
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && custom-elements-manifest analyze",
    "build:watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:verbose": "VITEST_REPORTER=verbose vitest run",
    "lint": "eslint src --ext .ts,.js --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "analyze": "custom-elements-manifest analyze",
    "clean": "rm -rf dist coverage .turbo"
  },
  "keywords": ["web-components", "lit", "design-system", "ui-components", "custom-elements"],
  "author": "Sando Design System Team",
  "license": "MIT",
  "dependencies": {
    "@sando-ds/tokens": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": false
    }
  },
  "devDependencies": {
    "lit": "^3.1.0",
    "@custom-elements-manifest/analyzer": "^0.9.0",
    "@open-wc/testing": "^4.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-lit": "^1.11.0",
    "eslint-plugin-wc": "^2.0.4",
    "jest-axe": "10.0.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
