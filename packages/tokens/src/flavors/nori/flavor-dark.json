{
  "$description": "Dark mode overrides for 'nori' flavor. Ink Precision stays dark-first — these overrides ensure explicit dark mode contexts maintain the same deep ink palette while slightly increasing surface contrast and control legibility. Automatically applied via @media (prefers-color-scheme: dark) and [flavor-mode='dark'].",
  "color": {
    "background": {
      "base": { "value": "{color.neutral.950.value}", "type": "color" },
      "surface": { "value": "{color.neutral.900.value}", "type": "color" },
      "raised": { "value": "{color.neutral.800.value}", "type": "color" },
      "overlay": { "value": "{color.neutral.950.value}", "type": "color" },
      "emphasis": { "value": "{color.amber.900.value}", "type": "color" },
      "hover": { "value": "{color.neutral.800.value}", "type": "color" }
    },
    "focus": {
      "ring": { "value": "{color.amber.400.value}", "type": "color" },
      "ring-offset": { "value": "{color.neutral.950.value}", "type": "color" },
      "background": { "value": "{color.amber.950.value}", "type": "color" },
      "text": { "value": "{color.amber.100.value}", "type": "color" }
    },
    "text": {
      "heading": { "value": "{color.neutral.50.value}", "type": "color" },
      "body": { "value": "{color.neutral.200.value}", "type": "color" },
      "caption": { "value": "{color.neutral.400.value}", "type": "color" },
      "muted": { "value": "{color.neutral.500.value}", "type": "color" },
      "on-solid": { "value": "{color.neutral.950.value}", "type": "color" },
      "link": {
        "default": { "value": "{color.amber.400.value}", "type": "color" },
        "hover": { "value": "{color.amber.300.value}", "type": "color" },
        "active": { "value": "{color.amber.200.value}", "type": "color" },
        "visited": { "value": "{color.amber.500.value}", "type": "color" },
        "focus": { "value": "{color.amber.400.value}", "type": "color" }
      }
    },
    "icon": {
      "default": { "value": "{color.neutral.400.value}", "type": "color" },
      "muted": { "value": "{color.neutral.500.value}", "type": "color" },
      "emphasis": { "value": "{color.neutral.100.value}", "type": "color" },
      "interactive": { "value": "{color.amber.400.value}", "type": "color" },
      "on-solid": { "value": "{color.neutral.950.value}", "type": "color" }
    },
    "border": {
      "muted": { "value": "{color.neutral.800.value}", "type": "color" },
      "default": { "value": "{color.neutral.600.value}", "type": "color" },
      "emphasis": { "value": "{color.amber.500.value}", "type": "color" },
      "on-solid": { "value": "{color.amber.600.value}", "type": "color" }
    },
    "action": {
      "solid": {
        "background": {
          "default": { "value": "{color.amber.500.value}", "type": "color" },
          "hover": { "value": "{color.amber.400.value}", "type": "color" }
        },
        "text": {
          "default": { "value": "{color.neutral.950.value}", "type": "color" }
        }
      },
      "outline": {
        "border": {
          "default": { "value": "{color.neutral.600.value}", "type": "color" },
          "hover": { "value": "{color.neutral.400.value}", "type": "color" }
        },
        "text": {
          "default": { "value": "{color.neutral.200.value}", "type": "color" }
        }
      },
      "ghost": {
        "background": {
          "hover": { "value": "{color.neutral.800.value}", "type": "color" }
        },
        "text": {
          "default": { "value": "{color.neutral.200.value}", "type": "color" }
        }
      },
      "disabled": {
        "background": { "value": "{color.neutral.800.value}", "type": "color" },
        "text": { "value": "{color.neutral.600.value}", "type": "color" },
        "border": { "value": "{color.neutral.700.value}", "type": "color" },
        "opacity": { "value": "{opacity.600.value}", "type": "number" }
      }
    },
    "state": {
      "destructive": {
        "background": { "value": "{color.red.900.value}", "type": "color" },
        "text": { "value": "{color.red.300.value}", "type": "color" },
        "border": { "value": "{color.red.700.value}", "type": "color" }
      },
      "success": {
        "background": { "value": "{color.green.900.value}", "type": "color" },
        "text": { "value": "{color.green.300.value}", "type": "color" },
        "border": { "value": "{color.green.700.value}", "type": "color" }
      },
      "warning": {
        "background": { "value": "{color.yellow.900.value}", "type": "color" },
        "text": { "value": "{color.yellow.300.value}", "type": "color" },
        "border": { "value": "{color.yellow.700.value}", "type": "color" }
      },
      "info": {
        "background": { "value": "{color.blue.900.value}", "type": "color" },
        "text": { "value": "{color.blue.300.value}", "type": "color" },
        "border": { "value": "{color.blue.700.value}", "type": "color" }
      }
    },
    "selection": {
      "background": { "value": "{color.amber.900.value}", "type": "color" },
      "text": { "value": "{color.neutral.50.value}", "type": "color" }
    },
    "control": {
      "surface": {
        "thumb": { "value": "{color.utility.white.value}", "type": "color" },
        "trackInactive": {
          "value": "{color.neutral.700.value}",
          "type": "color"
        },
        "trackActive": { "value": "{color.amber.500.value}", "type": "color" },
        "trackDisabled": {
          "value": "{color.neutral.800.value}",
          "type": "color"
        },
        "thumbDisabled": {
          "value": "{color.neutral.600.value}",
          "type": "color"
        }
      }
    }
  }
}
