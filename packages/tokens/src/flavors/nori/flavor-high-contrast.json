{
  "$description": "High contrast mode for 'nori' flavor. Maximum contrast ratios for enhanced accessibility (WCAG AAA compliance). Maintains ink-dark identity while prioritizing legibility. Automatically applied via @media (prefers-contrast: more) and [flavor-mode='high-contrast'].",
  "color": {
    "background": {
      "base": { "value": "{color.utility.black.value}", "type": "color" },
      "surface": { "value": "{color.utility.black.value}", "type": "color" },
      "raised": { "value": "{color.neutral.950.value}", "type": "color" },
      "overlay": { "value": "{color.utility.black.value}", "type": "color" },
      "emphasis": { "value": "{color.amber.950.value}", "type": "color" },
      "hover": { "value": "{color.neutral.900.value}", "type": "color" }
    },
    "focus": {
      "ring": { "value": "{color.amber.300.value}", "type": "color" },
      "ring-offset": {
        "value": "{color.utility.black.value}",
        "type": "color"
      },
      "background": { "value": "{color.amber.950.value}", "type": "color" },
      "text": { "value": "{color.amber.100.value}", "type": "color" }
    },
    "text": {
      "heading": { "value": "{color.utility.white.value}", "type": "color" },
      "body": { "value": "{color.utility.white.value}", "type": "color" },
      "caption": { "value": "{color.neutral.200.value}", "type": "color" },
      "link": {
        "default": { "value": "{color.amber.300.value}", "type": "color" },
        "hover": { "value": "{color.utility.white.value}", "type": "color" },
        "active": { "value": "{color.utility.white.value}", "type": "color" },
        "visited": { "value": "{color.amber.400.value}", "type": "color" },
        "focus": { "value": "{color.utility.white.value}", "type": "color" }
      },
      "muted": { "value": "{color.neutral.300.value}", "type": "color" },
      "on-solid": { "value": "{color.utility.black.value}", "type": "color" }
    },
    "icon": {
      "default": { "value": "{color.utility.white.value}", "type": "color" },
      "muted": { "value": "{color.neutral.300.value}", "type": "color" },
      "emphasis": { "value": "{color.utility.white.value}", "type": "color" },
      "interactive": { "value": "{color.amber.300.value}", "type": "color" },
      "on-solid": { "value": "{color.utility.black.value}", "type": "color" }
    },
    "border": {
      "muted": { "value": "{color.neutral.600.value}", "type": "color" },
      "default": { "value": "{color.neutral.400.value}", "type": "color" },
      "emphasis": { "value": "{color.amber.400.value}", "type": "color" }
    },
    "action": {
      "solid": {
        "background": {
          "default": { "value": "{color.amber.400.value}", "type": "color" },
          "hover": { "value": "{color.amber.300.value}", "type": "color" }
        },
        "text": {
          "default": { "value": "{color.utility.black.value}", "type": "color" }
        }
      },
      "outline": {
        "border": {
          "default": { "value": "{color.neutral.300.value}", "type": "color" },
          "hover": { "value": "{color.utility.white.value}", "type": "color" }
        },
        "text": {
          "default": { "value": "{color.utility.white.value}", "type": "color" }
        }
      },
      "ghost": {
        "background": {
          "hover": { "value": "{color.neutral.900.value}", "type": "color" }
        },
        "text": {
          "default": { "value": "{color.utility.white.value}", "type": "color" }
        }
      },
      "disabled": {
        "background": { "value": "{color.neutral.900.value}", "type": "color" },
        "text": { "value": "{color.neutral.500.value}", "type": "color" },
        "border": { "value": "{color.neutral.600.value}", "type": "color" },
        "opacity": { "value": "{opacity.600.value}", "type": "number" }
      }
    },
    "state": {
      "destructive": {
        "background": { "value": "{color.red.950.value}", "type": "color" },
        "text": { "value": "{color.red.200.value}", "type": "color" },
        "border": { "value": "{color.red.500.value}", "type": "color" }
      },
      "success": {
        "background": { "value": "{color.green.950.value}", "type": "color" },
        "text": { "value": "{color.green.200.value}", "type": "color" },
        "border": { "value": "{color.green.500.value}", "type": "color" }
      },
      "warning": {
        "background": { "value": "{color.yellow.950.value}", "type": "color" },
        "text": { "value": "{color.yellow.200.value}", "type": "color" },
        "border": { "value": "{color.yellow.500.value}", "type": "color" }
      },
      "info": {
        "background": { "value": "{color.blue.950.value}", "type": "color" },
        "text": { "value": "{color.blue.200.value}", "type": "color" },
        "border": { "value": "{color.blue.500.value}", "type": "color" }
      }
    },
    "selection": {
      "background": { "value": "{color.amber.500.value}", "type": "color" },
      "text": { "value": "{color.utility.black.value}", "type": "color" }
    },
    "control": {
      "surface": {
        "thumb": { "value": "{color.utility.white.value}", "type": "color" },
        "trackInactive": {
          "value": "{color.neutral.500.value}",
          "type": "color"
        },
        "trackActive": { "value": "{color.amber.400.value}", "type": "color" },
        "trackDisabled": {
          "value": "{color.neutral.800.value}",
          "type": "color"
        },
        "thumbDisabled": {
          "value": "{color.neutral.500.value}",
          "type": "color"
        }
      }
    }
  },
  "border": {
    "width": {
      "default": { "value": "{border.width.100.value}", "type": "dimension" },
      "emphasis": { "value": "{border.width.200.value}", "type": "dimension" }
    }
  },
  "focus": {
    "outline": {
      "width": { "value": "{border.width.150.value}", "type": "dimension" }
    }
  }
}
