{
  "$description": "High contrast mode for 'brutalist' flavor. Maximum contrast ratios for enhanced accessibility (WCAG AAA compliance). Uses pure black/white with vermillion accents where appropriate. Automatically applied via @media (prefers-contrast: more) and [flavor-mode='high-contrast'].",
  "color": {
    "background": {
      "base": { "value": "{color.utility.white.value}", "type": "color" },
      "surface": { "value": "{color.utility.white.value}", "type": "color" },
      "raised": { "value": "{color.utility.white.value}", "type": "color" },
      "overlay": { "value": "{color.utility.black.value}", "type": "color" },
      "emphasis": { "value": "{color.vermillion.100.value}", "type": "color" },
      "hover": { "value": "{color.ink.200.value}", "type": "color" }
    },
    "focus": {
      "ring": { "value": "{color.utility.black.value}", "type": "color" },
      "ring-offset": {
        "value": "{color.utility.white.value}",
        "type": "color"
      },
      "background": { "value": "{color.utility.white.value}", "type": "color" },
      "text": { "value": "{color.utility.black.value}", "type": "color" }
    },
    "text": {
      "heading": { "value": "{color.utility.black.value}", "type": "color" },
      "body": { "value": "{color.utility.black.value}", "type": "color" },
      "caption": { "value": "{color.vermillion.900.value}", "type": "color" },
      "link": {
        "default": { "value": "{color.vermillion.950.value}", "type": "color" },
        "hover": { "value": "{color.utility.black.value}", "type": "color" },
        "active": { "value": "{color.utility.black.value}", "type": "color" },
        "visited": { "value": "{color.vermillion.900.value}", "type": "color" },
        "focus": { "value": "{color.utility.black.value}", "type": "color" }
      },
      "muted": { "value": "{color.vermillion.700.value}", "type": "color" },
      "on-solid": { "value": "{color.utility.white.value}", "type": "color" }
    },
    "icon": {
      "default": { "value": "{color.utility.black.value}", "type": "color" },
      "muted": { "value": "{color.vermillion.700.value}", "type": "color" },
      "emphasis": { "value": "{color.utility.black.value}", "type": "color" },
      "interactive": {
        "value": "{color.vermillion.950.value}",
        "type": "color"
      },
      "on-solid": { "value": "{color.utility.white.value}", "type": "color" }
    },
    "border": {
      "muted": { "value": "{color.vermillion.600.value}", "type": "color" },
      "default": { "value": "{color.utility.black.value}", "type": "color" },
      "emphasis": { "value": "{color.utility.black.value}", "type": "color" }
    },
    "action": {
      "solid": {
        "background": {
          "default": {
            "value": "{color.utility.black.value}",
            "type": "color"
          },
          "hover": { "value": "{color.vermillion.900.value}", "type": "color" }
        },
        "text": {
          "default": { "value": "{color.utility.white.value}", "type": "color" }
        }
      },
      "outline": {
        "border": {
          "default": {
            "value": "{color.utility.black.value}",
            "type": "color"
          },
          "hover": { "value": "{color.utility.black.value}", "type": "color" }
        },
        "text": {
          "default": { "value": "{color.utility.black.value}", "type": "color" }
        }
      },
      "ghost": {
        "background": {
          "hover": { "value": "{color.vermillion.200.value}", "type": "color" }
        },
        "text": {
          "default": { "value": "{color.utility.black.value}", "type": "color" }
        }
      },
      "disabled": {
        "background": {
          "value": "{color.vermillion.200.value}",
          "type": "color"
        },
        "text": { "value": "{color.vermillion.600.value}", "type": "color" },
        "border": { "value": "{color.vermillion.500.value}", "type": "color" },
        "opacity": { "value": "{opacity.600.value}", "type": "number" }
      }
    },
    "state": {
      "destructive": {
        "background": {
          "value": "{color.state.error.100.value}",
          "type": "color"
        },
        "text": { "value": "{color.state.error.900.value}", "type": "color" },
        "border": { "value": "{color.state.error.900.value}", "type": "color" }
      },
      "success": {
        "background": {
          "value": "{color.state.success.100.value}",
          "type": "color"
        },
        "text": { "value": "{color.state.success.900.value}", "type": "color" },
        "border": {
          "value": "{color.state.success.900.value}",
          "type": "color"
        }
      },
      "warning": {
        "background": {
          "value": "{color.state.warning.100.value}",
          "type": "color"
        },
        "text": { "value": "{color.state.warning.700.value}", "type": "color" },
        "border": {
          "value": "{color.state.warning.700.value}",
          "type": "color"
        }
      },
      "info": {
        "background": {
          "value": "{color.state.info.100.value}",
          "type": "color"
        },
        "text": { "value": "{color.state.info.700.value}", "type": "color" },
        "border": {
          "value": "{color.state.info.700.value}",
          "type": "color"
        }
      }
    },
    "selection": {
      "background": { "value": "{color.utility.black.value}", "type": "color" },
      "text": { "value": "{color.utility.white.value}", "type": "color" }
    },
    "control": {
      "surface": {
        "thumb": {
          "value": "{color.utility.white.value}",
          "type": "color"
        },
        "trackInactive": {
          "value": "{color.utility.black.value}",
          "type": "color"
        },
        "trackActive": {
          "value": "{color.utility.black.value}",
          "type": "color"
        },
        "trackDisabled": {
          "value": "{color.vermillion.400.value}",
          "type": "color"
        },
        "thumbDisabled": {
          "value": "{color.vermillion.200.value}",
          "type": "color"
        }
      }
    }
  },
  "border": {
    "width": {
      "default": { "value": "{border.width.100.value}", "type": "dimension" },
      "emphasis": { "value": "{border.width.200.value}", "type": "dimension" }
    }
  },
  "focus": {
    "outline": {
      "width": { "value": "{border.width.150.value}", "type": "dimension" }
    }
  }
}
