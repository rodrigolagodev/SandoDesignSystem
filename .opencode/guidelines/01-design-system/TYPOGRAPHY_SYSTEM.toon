meta:
  doc_id: "TSYS"
  category: "01-design-system"
  version: "3.1.0"
  status: "Active"
  last_updated: "2026-06-14"
  owner: "UI Designer + Design System Architect"

purpose:
  id: "TSYS-PU"
  description: |
    Establishes scalable, accessible typographic foundation using the Warm Precision identity fonts (Outfit + Source Sans 3), modular scale, and responsive sizing. Operates through the three-layer token architecture. Typography is a brand expression — these fonts define the visual character of the Sando Design System.

core_rules:
  - id: "TSYS-CR-R1"
    title: "Web Font Stack — Warm Precision Identity (Non-Negotiable)"
    summary: "Use Outfit for headings and Source Sans 3 for body text. These are the official Sando DS brand fonts loaded via Google Fonts."
    fonts:
      heading:
        family: "Outfit"
        weights: [400, 600, 700]
        character: "Geometric, modern, clean — conveys precision and structure"
      body:
        family: "Source Sans 3"
        weights: [400, 600]
        character: "Humanist, warm, highly readable — conveys approachability"
      mono:
        family: "'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace"
        character: "System fallback — for code blocks and technical content"
    pattern:
      lang: "json"
      code:
        font:
          family:
            heading:
              value: "'Outfit', sans-serif"
              type: "fontFamily"
            body:
              value: "'Source Sans 3', sans-serif"
              type: "fontFamily"
            mono:
              value: "'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace"
              type: "fontFamily"
    loading:
      lang: "html"
      title: "Load via Google Fonts (link in document head)"
      code: |
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
          href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=Source+Sans+3:wght@400;600&display=swap"
          rel="stylesheet"
        />
    font_display: "Use `font-display: swap` to prevent FOIT (Flash of Invisible Text). Google Fonts includes this automatically."
    why: "Outfit + Source Sans 3 define the Warm Precision identity — the visual soul of the design system. Headings need geometric character (Outfit), body needs humanist readability (Source Sans 3). These are distinct roles requiring distinct fonts."
    anti_pattern:
      lang: "json"
      title: "❌ Using a single sans-serif for both heading and body (loses brand identity)"
      code:
        font:
          family:
            sans:
              value: "system-ui, sans-serif" # Generic, no brand identity
    reference:
      type: "source_file"
      path: "packages/tokens/src/ JSON source files"
      note: "complete font family token definitions"

  - id: "TSYS-CR-R2"
    title: "Modular Scale (Consistent Ratio)"
    summary: "Font sizes follow modular scale with ~1.125-1.25 ratio (Major Third to Perfect Fourth)."
    scale_definition:
      lang: "json"
      title: "Key Sizes"
      code:
        font:
          size:
            "100":
              value: "0.75rem"
              type: "dimension" # 12px - Captions
            "300":
              value: "1rem"
              type: "dimension" # 16px - BODY (default)
            "500":
              value: "1.25rem"
              type: "dimension" # 20px - Small headings
            "700":
              value: "2rem"
              type: "dimension" # 32px - Large headings
            "900":
              value: "3rem"
              type: "dimension" # 48px - Display
    constraints:
      - type: "MUST"
        note: "Use `rem` units (respects user preferences)"
      - type: "MUST"
        note: "Maintain consistent scale ratio"
      - type: "NEVER"
        note: "add custom sizes outside scale"
    anti_pattern:
      lang: "json"
      title: "❌ Arbitrary sizes break scale"
      code:
        font:
          size:
            custom:
              value: "1.3rem" # Not in scale

  - id: "TSYS-CR-R3"
    title: "Three-Layer Architecture"
    summary: "This operates at Layer 2 (Flavors) - provides semantic naming for typography."
    constraint: "Flavors reference ONLY Layer 1 (Ingredients), never Layer 3 (Recipes)."
    reference:
      type: "guideline"
      doc_id: "TA"
      file: "TOKEN_ARCHITECTURE.toon"
      note: "complete layer rules"
    pattern:
      lang: "json"
      code:
        # Layer 2: Flavors (semantic)
        layer_2:
          font:
            size:
              body:
                value: "{font.size.300.value}" # ✅ References Ingredient
              heading:
                value: "{font.size.700.value}"
        # Layer 3: Recipes (component-specific)
        layer_3:
          button:
            fontSize:
              value: "{font.size.body.value}" # ✅ References Flavor
    anti_pattern:
      lang: "json"
      title: "❌ Recipe skipping Flavors layer"
      code:
        button:
          fontSize:
            value: "{font.size.300.value}" # Recipe → Ingredient (WRONG)

  - id: "TSYS-CR-R4"
    title: "Semantic Naming (Context Over Size)"
    summary: "Flavors use contextual names, not size descriptors."
    pattern:
      lang: "json"
      title: "✅ Good - describes USE CONTEXT"
      code:
        font:
          size:
            body:
              value: "{font.size.300.value}" # Paragraph text
            caption:
              value: "{font.size.100.value}" # Small supplementary
            heading:
              value: "{font.size.700.value}" # Titles
    anti_pattern:
      lang: "json"
      title: "❌ Bad - describes VALUE"
      code:
        font:
          size:
            small:
              value: "{font.size.100.value}" # What is "small" for?
            medium:
              value: "{font.size.300.value}"
            large:
              value: "{font.size.700.value}"
    why: "`font.size.body` can map to 16px, 18px, or 20px depending on flavor—without changing component code."

  - id: "TSYS-CR-R5"
    title: "Unitless Line Heights (Proportional Scaling)"
    summary: "Always use unitless line height values so they scale proportionally with font size."
    pattern:
      lang: "json"
      code:
        font:
          lineHeight:
            "120":
              value: "1.2"
              type: "number" # ✅ Unitless - scales correctly
            "150":
              value: "1.5"
              type: "number" # WCAG minimum for body
    anti_pattern:
      lang: "json"
      code:
        font:
          lineHeight:
            default:
              value: "1.5rem"
              type: "dimension" # ❌ With unit - breaks scaling
    constraint:
      standard: "WCAG 2.1 AA"
      note: "Body text requires minimum **1.5** line height."

token_structure:
  - id: "TSYS-TS-L1"
    title: "Layer 1: Ingredients (Primitives)"
    font_families:
      lang: "json"
      title: "Font families — brand fonts + mono fallback"
      code:
        font:
          family:
            heading:
              value: "'Outfit', sans-serif"
              type: "fontFamily" # Geometric — headings, titles, display
            body:
              value: "'Source Sans 3', sans-serif"
              type: "fontFamily" # Humanist — body copy, labels, UI
            mono:
              value: "'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, Courier, monospace"
              type: "fontFamily" # Code blocks, technical content
    font_sizes:
      lang: "json"
      title: "Numeric scale - absolute values, no semantic meaning."
      code:
        font:
          size:
            "50":
              value: "0.625rem"
              type: "dimension" # 10px - Micro
            "100":
              value: "0.75rem"
              type: "dimension" # 12px - Captions
            "200":
              value: "0.875rem"
              type: "dimension" # 14px - Small
            "300":
              value: "1rem"
              type: "dimension" # 16px - DEFAULT
            "400":
              value: "1.125rem"
              type: "dimension" # 18px - Large body
            "500":
              value: "1.25rem"
              type: "dimension" # 20px - Small heading
            "600":
              value: "1.5rem"
              type: "dimension" # 24px - Medium heading
            "700":
              value: "2rem"
              type: "dimension" # 32px - Large heading
            "800":
              value: "2.5rem"
              type: "dimension" # 40px - XL heading
            "900":
              value: "3rem"
              type: "dimension" # 48px - Display
    font_weights:
      lang: "json"
      title: "Font Weights — Outfit (heading) supports 400/600/700, Source Sans 3 (body) supports 400/600"
      code:
        font:
          weight:
            "400":
              value: "400"
              type: "fontWeight" # Regular (body default)
            "600":
              value: "600"
              type: "fontWeight" # SemiBold (body emphasis, headings)
            "700":
              value: "700"
              type: "fontWeight" # Bold (heading emphasis)
    line_heights:
      lang: "json"
      title: "Line Heights (unitless multipliers)"
      code:
        font:
          lineHeight:
            "100":
              value: "1"
              type: "number" # Tight (badges)
            "120":
              value: "1.2"
              type: "number" # Headings
            "150":
              value: "1.5"
              type: "number" # Body (WCAG AA)
            "160":
              value: "1.6"
              type: "number" # Comfortable reading

  - id: "TSYS-TS-L2"
    title: "Layer 2: Flavors (Semantic)"
    summary: "Semantic tokens that reference ONLY Ingredients. Font family tokens map heading role to Outfit and body role to Source Sans 3."
    semantic_tokens:
      lang: "json"
      code:
        font:
          family:
            body:
              value: "{font.family.body.value}"  # Source Sans 3
              type: "fontFamily"
            heading:
              value: "{font.family.heading.value}"  # Outfit
              type: "fontFamily"
            code:
              value: "{font.family.mono.value}"
              type: "fontFamily"
          size:
            body:
              value: "{font.size.300.value}"
              type: "dimension" # 16px
            caption:
              value: "{font.size.100.value}"
              type: "dimension" # 12px
            heading-sm:
              value: "{font.size.500.value}"
              type: "dimension" # 20px
            heading-md:
              value: "clamp({font.size.600.value}, 5vw, {font.size.700.value})" # Responsive
              type: "dimension"
          weight:
            body:
              value: "{font.weight.400.value}"
              type: "fontWeight"
            body-emphasis:
              value: "{font.weight.600.value}"
              type: "fontWeight"
            heading:
              value: "{font.weight.700.value}"
              type: "fontWeight"
          lineHeight:
            body:
              value: "{font.lineHeight.150.value}"
              type: "number" # 1.5
            heading:
              value: "{font.lineHeight.120.value}"
              type: "number" # 1.2
    key_rule: "Heading and body font families MUST reference different Ingredient tokens. A flavor CAN override font families (e.g., a serif flavor could map heading to a different font), but MUST maintain the two-role separation."
    responsive_note:
      title: "Responsive Headings using clamp()"
      notes:
        - "Minimum size for mobile"
        - "Fluid scaling via viewport units"
        - "Maximum size for desktop"
        - "Uses `rem` to respect user preferences"

  - id: "TSYS-TS-L3"
    title: "Layer 3: Recipes (Component-Specific)"
    summary: "Recipes reference Flavors to define component typography."
    recipe_tokens:
      lang: "json"
      code:
        button:
          fontFamily:
            value: "{font.family.body.value}"
            type: "fontFamily"
          fontSize:
            value: "{font.size.body.value}"
            type: "dimension"
          fontWeight:
            value: "{font.weight.700.value}"
            type: "fontWeight" # Emphasis
          lineHeight:
            value: "{font.lineHeight.body.value}"
            type: "number"

component_implementation:
  id: "TSYS-CI"
  title: "Complete Pattern: Button Component example"
  recipe_tokens:
    lang: "json"
    title: "Recipe Tokens"
    path: "packages/tokens/src/recipes/button.json"
    code:
      button:
        fontFamily:
          value: "{font.family.body.value}" # Source Sans 3 — UI control
          type: "fontFamily"
        fontWeight:
          value: "{font.weight.600.value}" # SemiBold for legibility
          type: "fontWeight"
        lineHeight:
          value: "{font.lineHeight.body.value}"
          type: "number"
        size:
          sm:
            fontSize:
              value: "{font.size.caption.value}"
              type: "dimension"
              # 12px
          md:
            fontSize:
              value: "{font.size.body.value}"
              type: "dimension" # 16px
          lg:
            fontSize:
              value: "{font.size.body.value}"
              type: "dimension" # 16px
  component_consumption:
    lang: "typescript"
    file: "sando-button.ts"
    code: |
      import { css } from "lit";

      export const buttonStyles = css`
        button {
          font-family: var(--sando-button-fontFamily);
          font-weight: var(--sando-button-fontWeight);
          line-height: var(--sando-button-lineHeight);
        }

        :host([size="sm"]) button {
          font-size: var(--sando-button-size-sm-fontSize);
        }

        :host([size="md"]) button {
          font-size: var(--sando-button-size-md-fontSize);
        }

        :host([size="lg"]) button {
          font-size: var(--sando-button-size-lg-fontSize);
        }
      `;
  applicability: "All text-containing components (Cards, Inputs, Modals, etc.)"
  special_cases:
    - name: "Heading components (h1-h6, display text)"
      note: "Use `{font.family.heading.value}` (Outfit) — never mix heading font into body-level components"
    - name: "Body/UI components (buttons, inputs, labels)"
      note: "Use `{font.family.body.value}` (Source Sans 3) — consistent with body reading experience"
    - name: "Responsive headings"
      note: "Use `clamp()` in Flavors. See token_structure section above."
    - name: "Monospace code"
      note: "Use `{font.family.mono.value}` for code blocks and technical content"
    - name: "Different font stacks per flavor"
      note: "Override in `flavor.json` — but ALWAYS maintain the heading/body separation"

light_dom_activation:
  id: "TSYS-LDA"
  summary: "Declaring Flavor typography tokens is necessary but not sufficient. SOMETHING must apply them as concrete CSS properties or the document renders with browser defaults."
  problem: |
    Flavors declare `--sando-font-family-body`, `--sando-color-text-body`, etc.
    These cascade into Light DOM and Shadow DOM, but no rule reads them. Result:
    `<body>` and slot content use browser defaults (typically Times); the toolbar
    flavor switcher changes variables nobody consumes.
  two_bridges:
    summary: "Two CSS rules close the gap, one per DOM scope."
    bridges:
      - scope: "Light DOM"
        file: "`@sando-ds/tokens/css/base` (auto-generated preflight)"
        applies_to: ":where(:root, [data-flavor])"
        properties:
          - "font-family"
          - "font-size"
          - "font-weight"
          - "line-height"
          - "color"
          - "background-color"
        zero_specificity: "Uses `:where()` so any consumer rule trivially overrides it."
        nested_flavors: "Targets `[data-flavor]` too so subtree flavor swaps re-apply typography automatically."
      - scope: "Shadow DOM"
        file: "`packages/components/src/styles/reset.css.ts` (resetStyles)"
        applies_to: ":host"
        properties:
          - "font-family"
          - "line-height"
          - "color"
        slot_inheritance: "Slot content is in Light DOM but inherits from the host — applying typography on :host covers both shadow descendants and slotted children with one declaration."
        font_size_note: "font-size stays `inherit` to preserve consumer overrides like `sando-button { font-size: 1.25rem }`."
    consumer_setup:
      lang: "javascript"
      code: |
        // Light DOM activation
        import '@sando-ds/tokens/css/theme'; // or a single flavor: '@sando-ds/tokens/css/sando'
        import '@sando-ds/tokens/css/base';  // ← wires tokens to <body> / [data-flavor]

        // Shadow DOM activation is automatic — every component imports resetStyles first.
  rule:
    title: "TSYS-LDA-R1: Consumers MUST load `@sando-ds/tokens/css/base` (or equivalent)"
    note: "Without the base layer, pages render typography from browser defaults even when Flavor variables are loaded. The Shadow DOM bridge alone does not fix MDX/HTML content outside components."
    exception: "Consumers MAY substitute their own equivalent rule (e.g. when applying Sando tokens to an existing app theme), as long as it applies the four semantic properties listed above to the document root and any `[data-flavor]` subtrees."
  reference:
    - type: "guideline"
      doc_id: "CA"
      file: "../02-architecture/COMPONENT_ARCHITECTURE.toon"
      note: "CA-CR-R6 — Shadow DOM bridge (resetStyles)"
    - type: "adr"
      path: ".opencode/decisions/ADR-005-typography-activation.md"
      note: "Rationale for the two-bridge model"

responsive_typography:
  id: "TSYS-RT"
  rules:
    - title: "Using `clamp()` for Fluid Scaling"
      pattern:
        lang: "css"
        code: |
          /* Fluid scaling without media queries */
          font-size: clamp(
            1.5rem,  /* Minimum (mobile) */
            5vw,     /* Preferred (fluid) */
            2rem     /* Maximum (desktop) */
          );
      usage_guidelines:
        - type: "RECOMMENDED"
          elements:
            - "Large headings (h1, h2)"
            - "Hero text, display typography"
        - type: "NOT_RECOMMENDED"
          elements:
            - "Body text (fixed for readability)"
            - "UI controls (buttons, inputs)"

related_guidelines:
  - type: "guideline"
    doc_id: "TA"
    file: "TOKEN_ARCHITECTURE.toon"
    note: "Three-layer system rules"
  - type: "guideline"
    doc_id: "CS"
    file: "COLOR_SYSTEM.toon"
    note: "Text color contrast requirements"
  - type: "guideline"
    doc_id: "SS"
    file: "SPACING_SYSTEM.toon"
    note: "Vertical rhythm coordination"
  - type: "source_file"
    path: "packages/tokens/src/ JSON source files"
    note: "Complete font scales, stacks"