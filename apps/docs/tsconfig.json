{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Linting */
    "strict": true,

    /* Decorators for Lit — must match packages/components/tsconfig.json */
    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    /* JSX (required by @storybook/blocks / React) */
    "jsx": "react-jsx"
  },
  "include": ["stories/**/*", ".storybook/**/*"]
}
